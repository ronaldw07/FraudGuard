# Author: Ronald Wen
# Single-image deploy: the React frontend is built and served by the FastAPI
# backend on one URL. No separate frontend service, no CORS, no cross-service wiring.

FROM node:18-alpine AS frontend
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install
COPY frontend/ .
RUN npm run build

FROM python:3.11-slim
WORKDIR /app
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY backend/ .
COPY ml/explainability.py /ml/explainability.py
COPY --from=frontend /app/dist ./static

# Railway injects $PORT; fall back to 8000 for local runs.
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"]
