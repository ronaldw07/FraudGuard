# Author: Ronald Wen
# Copy this file to .env and fill in your values

# Local: postgresql://fraudguard:fraudguard@localhost:5432/fraudguard
# Production: use a free Postgres from https://neon.tech and paste its connection string here.
DATABASE_URL=postgresql://fraudguard:fraudguard@localhost:5432/fraudguard

# REQUIRED — the app refuses to start without it. Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-in-production

# Comma-separated list of allowed browser origins.
# Only matters if the frontend is hosted on a different origin than the API —
# in the single-image deploy (backend serves the frontend) this is unused.
CORS_ORIGINS=http://localhost:3000

# Set to "true" to auto-create the demo/fraudguard123 account on startup.
# Leave "false" (or unset) in production to avoid a known-credential login.
SEED_DEMO_USER=false
